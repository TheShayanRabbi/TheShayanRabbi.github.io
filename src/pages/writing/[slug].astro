---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../utils/content";

export async function getStaticPaths() {
  const entries = await getCollection("writing", ({ data }) => !data.draft);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Writing`} description={entry.data.description}>
  <section class="page-hero page-hero--compact">
    <p class="eyebrow">{entry.data.category}</p>
    <h1 class="page-title">{entry.data.title}</h1>
    <p class="page-hero__lede">{entry.data.description}</p>
    <ul class="page-meta-row">
      <li>{formatDate(entry.data.publishedAt)}</li>
      <li>{entry.data.readingTime}</li>
    </ul>
  </section>

  <article class="article-wrap">
    <div class="article surface">
      <Content />
    </div>
  </article>
</BaseLayout>
