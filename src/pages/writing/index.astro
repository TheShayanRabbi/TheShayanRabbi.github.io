---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/ContentCard.astro";
import { sortByPublishedDate } from "../../utils/content";

const writing = sortByPublishedDate(
  await getCollection("writing", ({ data }) => !data.draft),
);
---

<BaseLayout
  title="Writing | Shayan Rabbi"
  description="Essays, notes, and build logs by Shayan Rabbi."
>
  <section class="page-hero">
    <p class="eyebrow">Writing</p>
    <h1 class="page-title">Essays, notes, and fragments.</h1>
    <p class="page-hero__lede">
      Longer thoughts deserve a stable page instead of a disappearing feed.
    </p>
  </section>

  <section class="page-section">
    <div class="card-grid">
      {
        writing.map((entry) => (
          <ContentCard
            href={`/writing/${entry.id}/`}
            kicker={entry.data.category}
            title={entry.data.title}
            description={entry.data.description}
            meta={entry.data.readingTime}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
