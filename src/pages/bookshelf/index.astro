---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Book Shelf | Shayan Rabbi"
  description="Books and reading notes from Shayan Rabbi."
>
  <section class="page-hero">
    <p class="eyebrow">Book Shelf</p>
    <h1 class="page-title">Books, passages, and marginalia.</h1>
    <p class="page-hero__lede">
      A shelf for the books that stay in active use.
    </p>
  </section>

  <section class="placeholder-grid">
    <article class="placeholder-card surface">
      <p class="eyebrow">Soon</p>
      <h2>Current shelf</h2>
      <p>
        The structure is here. The actual shelf comes next.
      </p>
    </article>

    <article class="placeholder-card surface">
      <p class="eyebrow">Intent</p>
      <h2>Keep it selective</h2>
      <p>
        Better to show a small number of books that matter than an endless list with no point of view.
      </p>
    </article>
  </section>
</BaseLayout>
