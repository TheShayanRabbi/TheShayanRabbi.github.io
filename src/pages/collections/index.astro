---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Collections | Shayan Rabbi"
  description="Collections and curated references from Shayan Rabbi."
>
  <section class="page-hero">
    <p class="eyebrow">Collections</p>
    <h1 class="page-title">Objects, references, and ordered fragments.</h1>
    <p class="page-hero__lede">
      A place for ordered fragments.
    </p>
  </section>

  <section class="placeholder-grid">
    <article class="placeholder-card surface">
      <p class="eyebrow">Soon</p>
      <h2>Collected references</h2>
      <p>
        Links, objects, visual references, and useful fragments will live here once the categories settle.
      </p>
    </article>

    <article class="placeholder-card surface">
      <p class="eyebrow">Principle</p>
      <h2>Curate, do not dump</h2>
      <p>
        A collection needs selection pressure or it becomes a junk drawer.
      </p>
    </article>
  </section>
</BaseLayout>
