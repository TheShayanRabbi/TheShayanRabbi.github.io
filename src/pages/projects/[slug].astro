---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../utils/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Projects`} description={entry.data.description}>
  <article class="article-wrap">
    <div class="article surface">
      <header class="article-header">
        <p class="eyebrow">{entry.data.status}</p>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        <ul class="meta-list">
          <li>{formatDate(entry.data.publishedAt)}</li>
          {entry.data.tags.map((tag) => <li>{tag}</li>)}
          {entry.data.liveUrl && (
            <li><a href={entry.data.liveUrl}>Live link</a></li>
          )}
          {entry.data.repoUrl && (
            <li><a href={entry.data.repoUrl}>Repository</a></li>
          )}
        </ul>
      </header>

      <Content />
    </div>
  </article>
</BaseLayout>
