---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/ContentCard.astro";
import { sortByPublishedDate } from "../../utils/content";

const projects = sortByPublishedDate(await getCollection("projects"));
---

<BaseLayout
  title="Projects | Shayan Rabbi"
  description="Selected projects, experiments, and product work by Shayan Rabbi."
>
  <section class="page-hero">
    <p class="eyebrow">Projects</p>
    <h1 class="page-title">Products, systems, and experiments.</h1>
    <p class="page-hero__lede">
      A clean index of the work worth keeping in view.
    </p>
  </section>

  <section class="page-section">
    <div class="card-grid">
      {
        projects.map((project) => (
          <ContentCard
            href={`/projects/${project.id}/`}
            kicker={project.data.status}
            title={project.data.title}
            description={project.data.description}
            meta={project.data.tags.join(" / ")}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
