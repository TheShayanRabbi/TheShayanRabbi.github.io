---
interface Props {
  href: string;
  kicker: string;
  title: string;
  description: string;
  meta?: string;
}

const { href, kicker, title, description, meta } = Astro.props;
---

<article class="content-card surface">
  <p class="eyebrow">{kicker}</p>
  <h3>
    <a href={href}>{title}</a>
  </h3>
  <p>{description}</p>
  {meta && <p class="content-card__meta">{meta}</p>}
</article>
